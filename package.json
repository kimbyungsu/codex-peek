{
  "name": "codex-peek",
  "displayName": "Codex Peek",
  "description": "Codex CLI 세션의 마지막 출력과 최근 N턴 대화를 VS Code에서 바로 확인합니다. (읽기 전용, 로컬 ~/.codex 세션 파일 기반)",
  "version": "0.1.0",
  "publisher": "local",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kimbyungsu/codex-peek.git"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codexPeek.open",
        "title": "Codex Peek: 대화 보기 (최근 N턴)"
      },
      {
        "command": "codexPeek.lastOutput",
        "title": "Codex Peek: 마지막 출력만 보기"
      },
      {
        "command": "codexPeek.refresh",
        "title": "Codex Peek: 새로고침"
      }
    ],
    "configuration": {
      "title": "Codex Peek",
      "properties": {
        "codexPeek.codexHome": {
          "type": "string",
          "default": "",
          "description": "Codex 홈 폴더 경로입니다. 비우면 CODEX_HOME 또는 ~/.codex 를 사용합니다."
        },
        "codexPeek.defaultTurns": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "description": "대화 보기에서 기본으로 표시할 최근 턴 수입니다."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit -p ./",
    "clean:vsix": "node -e \"const fs=require('fs');fs.readdirSync('.').filter(f=>/^codex-peek-.*\\.vsix$/.test(f)).forEach(f=>fs.unlinkSync(f))\"",
    "package": "npm run compile && npm run clean:vsix && vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/vscode": "^1.96.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^5.7.2"
  }
}
